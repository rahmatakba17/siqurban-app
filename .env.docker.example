# ═══════════════════════════════════════════════════════════════
# SI Qurban — Environment Variables untuk Docker
# Salin file ini: cp .env.docker.example .env.docker
# JANGAN commit .env.docker ke Git!
# ═══════════════════════════════════════════════════════════════

# ── Aplikasi ──────────────────────────────────────────────────
APP_NAME="SI Qurban"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ── Port yang bisa dikustomisasi ──────────────────────────────
# Ganti jika port sudah dipakai aplikasi lain di komputer Anda
APP_PORT=8000
PMA_PORT=8080
REVERB_PORT=8090
MYSQL_PORT=3306

# ── Database (MySQL di dalam Docker) ─────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=siqurban
DB_USERNAME=siqurban
DB_PASSWORD=secret_siqurban_2025
DB_ROOT_PASSWORD=root_siqurban_2025

# ── Broadcasting — Reverb WebSocket ──────────────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=siqurban-app
REVERB_APP_KEY=siqurban-reverb-key-2025
REVERB_APP_SECRET=siqurban-reverb-secret-2025
REVERB_HOST=reverb
REVERB_PORT=8090
REVERB_SCHEME=http

VITE_REVERB_APP_KEY=siqurban-reverb-key-2025
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8090
VITE_REVERB_SCHEME=http

# ── Cache & Session ───────────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# ── Pulse Monitoring ─────────────────────────────────────────
PULSE_ENABLED=true
PULSE_RECORD_SLOW_REQUESTS=true
PULSE_SLOW_REQUEST_THRESHOLD=1000

# ── Sanctum API ───────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,localhost:8000
SANCTUM_ENCRYPT_COOKIES=false

# ── Mail ──────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@siqurban.local"
MAIL_FROM_NAME="${APP_NAME}"
